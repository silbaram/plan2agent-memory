{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/task-context.schema.json",
  "title": "Plan2Agent Task Context",
  "type": "object",
  "required": ["schema_version", "project_id", "active_iteration", "scope", "idea", "baseline_effective_spec_ref", "effective_spec", "existing_tasks", "spec_field_changes", "code_signals"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "p2a.task_context.v1"},
    "project_id": {"type": "string", "minLength": 1},
    "active_iteration": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "enum": ["feature", "maintenance"]},
    "idea": {"type": ["string", "null"]},
    "baseline_effective_spec_ref": {"type": ["string", "null"]},
    "effective_spec": {
      "type": "object",
      "required": ["product", "implementation"],
      "additionalProperties": false,
      "properties": {
        "product": {"type": "object"},
        "implementation": {"type": "object"}
      }
    },
    "existing_tasks": {
      "type": "object",
      "required": ["active", "maintenance"],
      "additionalProperties": false,
      "properties": {
        "active": {"type": "array", "items": {
          "type": "object",
          "required": ["id", "title", "status", "targetArea", "sourceSpecRefs"],
          "additionalProperties": false,
          "properties": {
            "id": {"type": "string", "pattern": "^task-[0-9]+$"},
            "title": {"type": "string", "minLength": 1},
            "status": {"type": "string", "enum": ["todo", "blocked", "in_progress", "done"]},
            "targetArea": {"type": "string", "minLength": 1},
            "sourceSpecRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          }
        }},
        "maintenance": {"type": "array", "items": {
          "type": "object",
          "required": ["id", "title", "status", "targetArea", "sourceSpecRefs"],
          "additionalProperties": false,
          "properties": {
            "id": {"type": "string", "pattern": "^task-[0-9]+$"},
            "title": {"type": "string", "minLength": 1},
            "status": {"type": "string", "enum": ["todo", "blocked", "in_progress", "done"]},
            "targetArea": {"type": "string", "minLength": 1},
            "sourceSpecRefs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          }
        }}
      }
    },
    "spec_field_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section", "field", "specRef"],
        "additionalProperties": false,
        "properties": {
          "section": {"type": "string", "enum": ["product", "implementation"]},
          "field": {"type": "string", "minLength": 1},
          "specRef": {"type": "string", "minLength": 1}
        }
      }
    },
    "code_signals": {
      "type": "object",
      "required": ["code_root", "file_tree", "truncated", "recent_changes"],
      "additionalProperties": false,
      "properties": {
        "code_root": {"type": ["string", "null"]},
        "file_tree": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "truncated": {"type": "boolean"},
        "recent_changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["taskId", "runId", "status", "changedFiles", "finishedAt"],
            "additionalProperties": false,
            "properties": {
              "taskId": {"type": "string", "pattern": "^task-[0-9]+$"},
              "runId": {"type": "string", "pattern": "^run-[A-Za-z0-9._-]+$"},
              "status": {"type": "string", "enum": ["started", "finished", "failed", "blocked"]},
              "changedFiles": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "finishedAt": {"type": ["string", "null"]}
            }
          }
        }
      }
    }
  }
}
