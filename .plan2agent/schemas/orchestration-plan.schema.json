{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/orchestration-plan.schema.json",
  "title": "Plan2Agent Supervised Orchestration Plan",
  "type": "object",
  "required": [
    "schema_version",
    "planId",
    "projectId",
    "taskId",
    "taskTitle",
    "sourceLayout",
    "sourceArgs",
    "sourceTaskGraph",
    "sourceSpec",
    "mode",
    "createdAt",
    "planner",
    "providerStrategy",
    "providerCapabilities",
    "roles",
    "acceptanceCriteria",
    "verificationPlan",
    "handoffPrompts",
    "monitorGate",
    "riskFlags",
    "runLink"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.orchestration_plan.v1"
    },
    "planId": {
      "type": "string",
      "pattern": "^orch-[A-Za-z0-9._-]+$"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "pattern": "^task-[0-9]+$"
    },
    "taskTitle": {
      "type": "string",
      "minLength": 1
    },
    "sourceLayout": {
      "type": "string",
      "enum": [
        "iteration",
        "maintenance",
        "handoff",
        "graph"
      ]
    },
    "sourceArgs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceTaskGraph": {
      "type": "string",
      "minLength": 1
    },
    "sourceSpec": {
      "type": [
        "string",
        "null"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "solo",
        "solo_monitor",
        "team"
      ]
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "planner": {
      "type": "object",
      "required": [
        "type",
        "name",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "deterministic"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerStrategy": {
      "type": "object",
      "required": [
        "mode",
        "primaryProvider",
        "implementationProvider",
        "reviewProvider",
        "monitorProvider",
        "mixedProviderImplementation",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "single_provider",
            "single_provider_with_read_only_reviewer",
            "manual"
          ]
        },
        "primaryProvider": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "gemini",
            "manual"
          ]
        },
        "implementationProvider": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "gemini",
            "manual"
          ]
        },
        "reviewProvider": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "codex",
            "claude",
            "gemini",
            "manual",
            null
          ]
        },
        "monitorProvider": {
          "type": "string",
          "enum": [
            "manual"
          ]
        },
        "mixedProviderImplementation": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "providerCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "provider",
          "roles",
          "writeAllowed",
          "executionSurface",
          "officialFeatures",
          "supervisionMode",
          "restrictions"
        ],
        "additionalProperties": false,
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "codex",
              "claude",
              "gemini",
              "manual"
            ]
          },
          "roles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "lead",
                "contributor",
                "reviewer",
                "monitor"
              ]
            }
          },
          "writeAllowed": {
            "type": "boolean"
          },
          "executionSurface": {
            "type": "string",
            "minLength": 1
          },
          "officialFeatures": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "supervisionMode": {
            "type": "string",
            "enum": [
              "foreground_human_supervised"
            ]
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
          "required": [
            "roleId",
            "role",
            "profile",
            "profileSource",
            "profileReason",
            "agentTool",
            "executionGuide",
            "scope",
            "prompt",
          "requiresWrite"
        ],
        "additionalProperties": false,
        "properties": {
          "roleId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "role": {
            "type": "string",
            "enum": [
              "lead",
              "contributor",
              "reviewer",
              "monitor"
            ]
          },
          "profile": {
            "type": "string",
            "enum": [
              "owner_supervisor",
              "frontend_implementer",
              "backend_implementer",
              "fullstack_implementer",
              "test_implementer",
              "docs_implementer",
              "qa_reviewer",
              "architecture_reviewer",
              "security_reviewer",
              "manual_monitor"
            ]
          },
          "profileSource": {
            "type": "string",
            "enum": [
              "auto",
              "override"
            ]
          },
          "profileReason": {
            "type": "string",
            "minLength": 1
          },
          "agentTool": {
            "type": "string",
            "enum": [
              "codex",
              "claude",
              "gemini",
              "manual"
            ]
          },
          "executionGuide": {
            "type": "object",
            "required": [
              "surface",
              "recommendedFeature",
              "fallbackMode",
              "supervisionRequired",
              "startsProcess",
              "constraints"
            ],
            "additionalProperties": false,
            "properties": {
              "surface": {
                "type": "string",
                "minLength": 1
              },
              "recommendedFeature": {
                "type": "string",
                "minLength": 1
              },
              "fallbackMode": {
                "type": "string",
                "minLength": 1
              },
              "supervisionRequired": {
                "const": true
              },
              "startsProcess": {
                "const": false
              },
              "constraints": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "requiresWrite": {
            "type": "boolean"
          }
        }
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verificationPlan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "command",
          "required"
        ],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "test",
              "lint",
              "typecheck",
              "custom"
            ]
          },
          "command": {
            "type": [
              "string",
              "null"
            ]
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "handoffPrompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "roleId",
          "command",
          "prompt"
        ],
        "additionalProperties": false,
        "properties": {
          "roleId": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": [
              "string",
              "null"
            ]
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "monitorGate": {
      "type": "object",
      "required": [
        "required",
        "verdictPath",
        "acceptedVerdicts",
        "failureClassMap"
      ],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "verdictPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "acceptedVerdicts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "failureClassMap": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "block": {
              "type": "string",
              "enum": [
                "verification_failed",
                "test_flake",
                "scope_violation",
                "missing_dependency",
                "environment_failure",
                "implementation_incomplete",
                "other"
              ]
            },
            "scope_concerns": {
              "type": "string",
              "enum": [
                "verification_failed",
                "test_flake",
                "scope_violation",
                "missing_dependency",
                "environment_failure",
                "implementation_incomplete",
                "other"
              ]
            },
            "verification_concerns": {
              "type": "string",
              "enum": [
                "verification_failed",
                "test_flake",
                "scope_violation",
                "missing_dependency",
                "environment_failure",
                "implementation_incomplete",
                "other"
              ]
            },
            "unmet_acceptance": {
              "type": "string",
              "enum": [
                "verification_failed",
                "test_flake",
                "scope_violation",
                "missing_dependency",
                "environment_failure",
                "implementation_incomplete",
                "other"
              ]
            },
            "needs_user_decision": {
              "type": "string",
              "enum": [
                "verification_failed",
                "test_flake",
                "scope_violation",
                "missing_dependency",
                "environment_failure",
                "implementation_incomplete",
                "other"
              ]
            }
          }
        }
      }
    },
    "riskFlags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "multi_area",
          "high_acceptance_count",
          "dependency_heavy",
          "monitor_required",
          "reviewer_recommended",
          "read_only_reviewer"
        ]
      }
    },
    "runLink": {
      "type": "object",
      "required": [
        "runId",
        "sidecarRef"
      ],
      "additionalProperties": false,
      "properties": {
        "runId": {
          "type": [
            "string",
            "null"
          ]
        },
        "sidecarRef": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
