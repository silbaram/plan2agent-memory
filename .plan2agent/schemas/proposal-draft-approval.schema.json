{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/proposal-draft-approval.schema.json",
  "title": "Plan2Agent Proposal Draft Approval",
  "type": "object",
  "required": [
    "schema_version",
    "approvalId",
    "approvedAt",
    "approvedBy",
    "approvalNote",
    "sourceDraft",
    "draftId",
    "candidateId",
    "autoApplyPerformed",
    "maintenanceTask"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.proposal_draft_approval.v1"
    },
    "approvalId": {
      "type": "string",
      "pattern": "^proposal-draft-approval-[a-f0-9]{12}$"
    },
    "approvedAt": {
      "type": "string",
      "minLength": 1
    },
    "approvedBy": {
      "type": "string",
      "minLength": 1
    },
    "approvalNote": {
      "type": ["string", "null"]
    },
    "sourceDraft": {
      "type": "string",
      "minLength": 1
    },
    "draftId": {
      "type": "string",
      "pattern": "^proposal-patch-draft-[a-f0-9]{12}$"
    },
    "candidateId": {
      "type": "string",
      "pattern": "^candidate-[a-f0-9]{12}$"
    },
    "autoApplyPerformed": {
      "type": "boolean"
    },
    "maintenanceTask": {
      "type": "object",
      "required": ["taskGraph", "taskId", "title", "sourceSpecRefs"],
      "additionalProperties": false,
      "properties": {
        "taskGraph": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "pattern": "^task-[0-9]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "sourceSpecRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
