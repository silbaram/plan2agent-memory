{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/intake.schema.json",
  "title": "Plan2Agent Intake Artifact",
  "type": "object",
  "required": [
    "schema_version",
    "idea",
    "summary",
    "known_facts",
    "assumptions",
    "clarifying_questions",
    "needs_user_decision",
    "status",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.intake.v1"
    },
    "idea": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "known_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "risk",
          "confirmation_needed"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^A-[0-9]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "confirmation_needed": {
            "type": "boolean"
          }
        }
      }
    },
    "clarifying_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "question",
          "why_it_matters",
          "blocks"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CQ-[0-9]+$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 1
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "needs_user_decision": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "question",
          "options",
          "impact",
          "default",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ND-[0-9]+$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "id",
                "label",
                "description"
              ],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "default": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "answered",
              "deferred"
            ]
          },
          "answer": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "blocked_on_user",
        "ready_for_spec"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "url",
          "used_for"
        ],
        "additionalProperties": false,
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^(WEB|USER|LOCAL)-[0-9]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string"
          },
          "used_for": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
