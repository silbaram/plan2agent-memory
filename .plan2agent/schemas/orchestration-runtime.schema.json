{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/orchestration-runtime.schema.json",
  "title": "Plan2Agent Orchestration Runtime",
  "type": "object",
  "required": [
    "schema_version",
    "runtimeId",
    "projectId",
    "taskId",
    "taskTitle",
    "runId",
    "planId",
    "mode",
    "sourcePlanRef",
    "createdAt",
    "updatedAt",
    "sharedMentalModel",
    "communicationLog",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.orchestration_runtime.v1"
    },
    "runtimeId": {
      "type": "string",
      "pattern": "^runtime-[A-Za-z0-9._-]+$"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "pattern": "^task-[0-9]+$"
    },
    "taskTitle": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$"
    },
    "planId": {
      "type": "string",
      "pattern": "^orch-[A-Za-z0-9._-]+$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "solo",
        "solo_monitor",
        "team"
      ]
    },
    "sourcePlanRef": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    },
    "sharedMentalModel": {
      "type": "object",
      "required": [
        "objective",
        "currentState",
        "constraints",
        "acceptanceCriteria",
        "roleAssignments",
        "decisions",
        "openQuestions",
        "risks"
      ],
      "additionalProperties": false,
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "currentState": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptanceCriteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "roleAssignments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "roleId",
              "role",
              "profile",
              "profileSource",
              "profileReason",
              "agentTool",
              "executionGuide",
              "scope",
              "status"
            ],
            "additionalProperties": false,
            "properties": {
              "roleId": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._-]+$"
              },
              "role": {
                "type": "string",
                "enum": [
                  "lead",
                  "contributor",
                  "reviewer",
                  "monitor"
                ]
              },
              "profile": {
                "type": "string",
                "enum": [
                  "owner_supervisor",
                  "frontend_implementer",
                  "backend_implementer",
                  "fullstack_implementer",
                  "test_implementer",
                  "docs_implementer",
                  "qa_reviewer",
                  "architecture_reviewer",
                  "security_reviewer",
                  "manual_monitor"
                ]
              },
              "profileSource": {
                "type": "string",
                "enum": [
                  "auto",
                  "override"
                ]
              },
              "profileReason": {
                "type": "string",
                "minLength": 1
              },
              "agentTool": {
                "type": "string",
                "enum": [
                  "codex",
                  "claude",
                  "gemini",
                  "manual"
                ]
              },
              "executionGuide": {
                "type": "object",
                "required": [
                  "surface",
                  "recommendedFeature",
                  "fallbackMode",
                  "supervisionRequired",
                  "startsProcess",
                  "constraints"
                ],
                "additionalProperties": false,
                "properties": {
                  "surface": {
                    "type": "string",
                    "minLength": 1
                  },
                  "recommendedFeature": {
                    "type": "string",
                    "minLength": 1
                  },
                  "fallbackMode": {
                    "type": "string",
                    "minLength": 1
                  },
                  "supervisionRequired": {
                    "const": true
                  },
                  "startsProcess": {
                    "const": false
                  },
                  "constraints": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              },
              "scope": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "active",
                  "blocked",
                  "complete",
                  "skipped"
                ]
              }
            }
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "decisionId",
              "summary",
              "rationale",
              "createdAt",
              "roleId"
            ],
            "additionalProperties": false,
            "properties": {
              "decisionId": {
                "type": "string",
                "pattern": "^decision-[A-Za-z0-9._-]+$"
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "rationale": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "createdAt": {
                "type": "string",
                "minLength": 1
              },
              "roleId": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "openQuestions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "questionId",
              "summary",
              "askedByRoleId",
              "targetRoleId",
              "status",
              "answer",
              "createdAt",
              "answeredAt"
            ],
            "additionalProperties": false,
            "properties": {
              "questionId": {
                "type": "string",
                "pattern": "^question-[A-Za-z0-9._-]+$"
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "askedByRoleId": {
                "type": "string",
                "minLength": 1
              },
              "targetRoleId": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "open",
                  "answered",
                  "deferred"
                ]
              },
              "answer": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "createdAt": {
                "type": "string",
                "minLength": 1
              },
              "answeredAt": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "communicationLog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "eventId",
          "createdAt",
          "roleId",
          "role",
          "agentTool",
          "type",
          "summary",
          "detail",
          "linkedRoleId",
          "requiresOwnerAction"
        ],
        "additionalProperties": false,
        "properties": {
          "eventId": {
            "type": "string",
            "pattern": "^event-[A-Za-z0-9._-]+$"
          },
          "createdAt": {
            "type": "string",
            "minLength": 1
          },
          "roleId": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "lead",
              "contributor",
              "reviewer",
              "monitor"
            ]
          },
          "agentTool": {
            "type": "string",
            "enum": [
              "codex",
              "claude",
              "gemini",
              "manual"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "handoff",
              "status",
              "question",
              "answer",
              "ack",
              "concern",
              "decision",
              "blocker",
              "verification",
              "monitor_verdict",
              "owner_note"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": [
              "string",
              "null"
            ]
          },
          "linkedRoleId": {
            "type": [
              "string",
              "null"
            ]
          },
          "requiresOwnerAction": {
            "type": "boolean"
          }
        }
      }
    },
    "status": {
      "type": "object",
      "required": [
        "phase",
        "blocked",
        "needsUserDecision",
        "lastEventId"
      ],
      "additionalProperties": false,
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "initialized",
            "running",
            "blocked",
            "ready_for_monitor",
            "ready_to_finish",
            "closed"
          ]
        },
        "blocked": {
          "type": "boolean"
        },
        "needsUserDecision": {
          "type": "boolean"
        },
        "lastEventId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
