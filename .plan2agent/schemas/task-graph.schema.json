{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan2agent.local/schemas/task-graph.schema.json",
  "title": "Plan2Agent Task Graph",
  "type": "object",
  "required": [
    "schema_version",
    "projectId",
    "version",
    "sourceSpec",
    "tasks"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "p2a.task_graph.v1"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "sourceSpec": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "status",
          "dependencies",
          "acceptanceCriteria",
          "targetArea",
          "suggestedAgentPrompt",
          "sourceSpecRefs"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^task-[0-9]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "todo",
              "blocked",
              "in_progress",
              "done"
            ]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^task-[0-9]+$"
            }
          },
          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "targetArea": {
            "type": "string",
            "description": "Single area label by default. When a task intentionally spans multiple areas, separate area labels with comma, plus, ampersand, or the word 'and'. Slash is treated as a literal label character, not a multi-area separator.",
            "minLength": 1
          },
          "suggestedAgentPrompt": {
            "type": "string",
            "minLength": 1
          },
          "sourceSpecRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "blockReason": {
            "type": "string",
            "enum": [
              "verification_failed",
              "test_flake",
              "scope_violation",
              "missing_dependency",
              "environment_failure",
              "implementation_incomplete",
              "other"
            ]
          }
        }
      }
    }
  }
}
